# ── 지도 표시 (네이버 클라우드 플랫폼 Maps > Web Dynamic Map Key ID) ──
NEXT_PUBLIC_NCP_KEY_ID=

# ── 배포 읽기 DB: Cloudflare D1 (Vercel 환경변수에 등록) ──
# 로컬 개발/수집은 이 값들이 없으면 로컬 SQLite(data/house.db)를 쓴다.
# 로컬 D1 동기화(sync:d1)에는 .env.collect.local에 아래 3개를 넣는다.
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=

# ── 접속 비밀번호 (비우면 인증 없음 — 로컬 개발용) ──
APP_PASSWORD=

# ── 수집 튜닝 (선택) ──
# NAVER_DELAY_MS=600              # 네이버 요청 간 딜레이
# KB_DELAY_MS=400                 # KB부동산 요청 간 딜레이
# MAX_PRICE_MANWON=100000         # 호가 상한 (만원, 기본 10억) — 이상 매물 수집·저장 안 함
# DEACTIVATE_GRACE_DAYS=2         # 이 일수 이상 안 보이면 매물 비활성화(화면 제거)
# HARD_DELETE_DAYS=30             # 이 일수 이상 안 보이면 완전 삭제
# BOGEUMJARI_LIMIT=60000          # 보금자리론 기준 (만원, 기본 6억)
# TRADES_BACKFILL_FROM_YEAR=2015  # 실거래 백필 시작 연도
# URGENT_DISCOUNT=0.95            # 급매 기준 (평균 호가 대비 비율)
